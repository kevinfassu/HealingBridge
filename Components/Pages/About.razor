@page "/about"
<PageTitle>About Us — Healing Bridge Health</PageTitle>

@* ── PAGE HERO ── *@
<section class="page-hero">
  <div class="hb-container page-hero-inner">
    <p class="hero-label" data-i18n="about.label">WHO WE ARE</p>
    <h1 class="page-hero-title" data-i18n="about.title">About Healing Bridge Health</h1>
    <p class="page-hero-sub" data-i18n="about.sub">
      A licensed, 6-bed Congregate Living Health Facility in the North San Fernando Valley—dedicated to
      bridging the gap between hospital and home with compassionate, expert post-acute care.
    </p>
  </div>
</section>

@* ── OUR STORY ── *@
<section class="sect sect-story">
  <div class="hb-container grid-2 align-center">
    <div class="col-text">
      <p class="sect-label" data-i18n="about.story_label">Our Story</p>
      <h2 class="sect-heading" data-i18n="about.story_heading">Built Around the Bridge</h2>
      <p class="sect-body" data-i18n="about.story_body1">
        Healing Bridge Health, Inc. opened its doors in <strong>November 2024</strong> with a clear purpose:
        to give patients leaving the hospital a place that feels nothing like a hospital. We saw families
        struggling to find the right setting after a critical illness or injury — somewhere skilled enough
        to handle complex medical needs, but warm enough to feel like home.
      </p>
      <p class="sect-body" data-i18n="about.story_body2">
        Our 6-bed licensed facility in North Hollywood was designed from the ground up to be that bridge.
        Every detail — from the natural light in our bedrooms, to our experienced leadership team, to the
        sophisticated medical equipment — was chosen to support faster, more dignified recovery.
      </p>
      <div class="story-stats">
        <div class="story-stat">
          <span class="story-stat-num" data-i18n="about.s_year">2024</span>
          <span class="story-stat-label" data-i18n="about.s_year_l">Founded</span>
        </div>
        <div class="story-stat">
          <span class="story-stat-num" data-i18n="about.s_beds">6</span>
          <span class="story-stat-label" data-i18n="about.s_beds_l">Licensed Beds</span>
        </div>
        <div class="story-stat">
          <span class="story-stat-num" data-i18n="about.s_lang">3</span>
          <span class="story-stat-label" data-i18n="about.s_lang_l">Languages Spoken</span>
        </div>
        <div class="story-stat">
          <span class="story-stat-num" data-i18n="about.s_247">24/7</span>
          <span class="story-stat-label" data-i18n="about.s_247_l">Skilled Nursing</span>
        </div>
      </div>
    </div>
    <div class="col-media">
      <img src="/Media/story.jpg" alt="Healing Bridge Health facility" class="sect-img" />
    </div>
  </div>
</section>

@* ── MISSION ── *@
<section class="sect sect-mission alt">
  <div class="hb-container grid-2 align-center grid-reverse">
    <div class="col-text">
      <p class="sect-label" data-i18n="about.mission_label">Our Mission</p>
      <h2 class="sect-heading" data-i18n="about.mission_heading">A Seamless Transition to Optimal Health</h2>
      <p class="sect-body" data-i18n="about.mission_body">
        At Healing Bridge Health, we believe in a seamless transition to the optimal health of our patients.
        Our mission is to provide compassionate, personalized support for patients moving from acute care
        to home or other healthcare institutions. We bridge the gap with expert care coordination, ensuring
        each individual's journey to recovery is smooth, supported, and empowered with evidence-informed
        and patient-centered care.
      </p>
    </div>
    <div class="col-media">
      <img src="/Media/mission.jpg" alt="Patient room" class="sect-img" />
    </div>
  </div>
</section>

@* ── VISION ── *@
<section class="sect sect-vision">
  <div class="hb-container grid-2 align-center">
    <div class="col-media">
      <img src="/Media/vision.jpg" alt="Healing Bridge interior" class="sect-img" />
    </div>
    <div class="col-text">
      <p class="sect-label" data-i18n="about.vision_label">Our Vision</p>
      <h2 class="sect-heading" data-i18n="about.vision_heading">Setting a New Standard in Patient-Centered Care</h2>
      <p class="sect-body" data-i18n="about.vision_body">
        At Healing Bridge Health, we envision a healthcare continuum where every transition is seamless, supportive, and centered on the individual's path to recovery. 
        We strive to bridge the gap between hospitalization and independent living by providing compassionate, clinically advanced care in a comfortable, home-like environment.
      </p>
    </div>
  </div>
</section>

