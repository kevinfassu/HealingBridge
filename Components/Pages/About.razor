@* ── OUR APPROACH ── *@
<section class="sect sect-approach alt">
  <div class="hb-container">
    <div class="services-header">
      <p class="sect-label" data-i18n="about.app_label">Our Approach</p>
      <h2 class="sect-heading" data-i18n="about.app_heading">Three Principles That Guide Every Decision</h2>
    </div>
    <div class="approach-grid">
      <div class="approach-card">
        <span class="approach-num">01</span>
        <h3 data-i18n="about.a1_title">Patient-Centered</h3>
        <p data-i18n="about.a1_body">Every care plan is built around the individual — their medical needs, recovery goals, preferences, and dignity. There are no one-size-fits-all programs here.</p>
      </div>
      <div class="approach-card">
        <span class="approach-num">02</span>
        <h3 data-i18n="about.a2_title">Family-Inclusive</h3>
        <p data-i18n="about.a2_body">Families aren't visitors here — they're part of the team. We keep loved ones informed, involved in care decisions, and welcome every day during visiting hours.</p>
      </div>
      <div class="approach-card">
        <span class="approach-num">03</span>
        <h3 data-i18n="about.a3_title">Evidence-Informed</h3>
        <p data-i18n="about.a3_body">Our protocols follow the latest clinical research and best practices. We use sophisticated equipment and therapies proven to support faster, safer recovery.</p>
      </div>
    </div>
  </div>
</section>

