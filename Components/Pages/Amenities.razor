@page "/amenities"
<PageTitle>Amenities — Healing Bridge Health</PageTitle>

@* ── PAGE HERO ── *@
<section class="page-hero">
  <div class="hb-container page-hero-inner">
    <p class="hero-label" data-i18n="amen.label">A HOME-LIKE ENVIRONMENT</p>
    <h1 class="page-hero-title" data-i18n="amen.title">Our Amenities</h1>
    <p class="page-hero-sub" data-i18n="amen.sub">
      A non-institutional, home-like Congregate Living Health Facility designed for comfort, dignity,
      and quicker recovery.
    </p>
  </div>
</section>

@* ── AMENITIES HIGHLIGHTS ── *@
<section class="sect sect-amen-highlights">
  <div class="hb-container">
    <div class="services-header">
      <p class="sect-label" data-i18n="amen.h_label">Why It Feels Different</p>
      <h2 class="sect-heading" data-i18n="amen.h_heading">Designed Around Comfort &amp; Care</h2>
    </div>
    <div class="amen-cards">
      <div class="amen-card">
        <div class="amen-card-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 28L32 8l24 20"/><path d="M14 28v24h36V28"/><rect x="26" y="36" width="12" height="16"/>
          </svg>
        </div>
        <h3 data-i18n="amen.h1_title">Home-Like Environment</h3>
        <p data-i18n="amen.h1_body">A non-institutional setting that creates surroundings conducive to quicker recovery.</p>
      </div>
      <div class="amen-card">
        <div class="amen-card-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="10" y="20" width="44" height="28" rx="3"/><path d="M18 20V14a4 4 0 0 1 4-4h20a4 4 0 0 1 4 4v6"/>
            <path d="M32 28v12M26 34h12"/>
          </svg>
        </div>
        <h3 data-i18n="amen.h2_title">Sophisticated Equipment</h3>
        <p data-i18n="amen.h2_body">State-of-the-art medical and rehabilitation technology supporting every stage of care.</p>
      </div>
      <div class="amen-card">
        <div class="amen-card-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M32 8c-8 0-14 6-14 14 0 6 4 10 8 12v6h12v-6c4-2 8-6 8-12 0-8-6-14-14-14z"/>
            <path d="M26 50h12M28 56h8"/>
          </svg>
        </div>
        <h3 data-i18n="amen.h3_title">Outdoor Therapeutic Area</h3>
        <p data-i18n="amen.h3_body">A peaceful outdoor space that supports recovery, fresh air, and gentle movement.</p>
      </div>
      <div class="amen-card">
        <div class="amen-card-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="8" y="22" width="48" height="22" rx="3"/>
            <path d="M16 22v-4M48 22v-4M8 32h48M16 50v4M48 50v4"/>
          </svg>
        </div>
        <h3 data-i18n="amen.h4_title">Comfortable Bedrooms</h3>
        <p data-i18n="amen.h4_body">Bedrooms designed to feel like home, helping patients rest and recover with dignity.</p>
      </div>
      <div class="amen-card">
        <div class="amen-card-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="32" cy="32" r="22"/><path d="M22 32l8 8 14-14"/>
          </svg>
        </div>
        <h3 data-i18n="amen.h5_title">24/7 Skilled Staffing</h3>
        <p data-i18n="amen.h5_body">An interdisciplinary team available around the clock to deliver complex, restorative care.</p>
      </div>
      <div class="amen-card">
        <div class="amen-card-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 28h48M14 28v20h36V28M22 16h20l4 12H18l4-12z"/>
          </svg>
        </div>
        <h3 data-i18n="amen.h6_title">Convenient Location</h3>
        <p data-i18n="amen.h6_body">In the North San Fernando Valley—near medical centers, shopping, and freeways for easy visits.</p>
      </div>
    </div>
  </div>
</section>

@* ── ALTERNATING FEATURE ROWS ── *@
@* Row 1 — Welcoming Lobby *@
<section class="sect sect-amen-row">
  <div class="hb-container grid-2 align-center">
    <div class="col-media">
      <img src="/Media/IMG_0407.JPEG" alt="Welcoming lobby and reception" class="sect-img" />
    </div>
    <div class="col-text">
      <p class="sect-label" data-i18n="amen.r1_label">Reception &amp; Lobby</p>
      <h2 class="sect-heading" data-i18n="amen.r1_heading">A Warm First Impression</h2>
      <p class="sect-body" data-i18n="amen.r1_body">
        Our welcoming lobby and reception sets the tone for the warmth and professionalism patients and
        families experience throughout their stay. Bright, calming, and thoughtfully decorated.
      </p>
    </div>
  </div>
</section>

@* Row 2 — Bedrooms *@
<section class="sect sect-amen-row alt">
  <div class="hb-container grid-2 align-center grid-reverse">
    <div class="col-text">
      <p class="sect-label" data-i18n="amen.r2_label">Patient Bedrooms</p>
      <h2 class="sect-heading" data-i18n="amen.r2_heading">Restful Rooms That Feel Like Home</h2>
      <p class="sect-body" data-i18n="amen.r2_body">
        Each bedroom is equipped with a hospital-grade bed, call system, and personal touches—greenery,
        lamps, and warm wood furniture—to ease the transition from hospital to home.
      </p>
    </div>
    <div class="col-media">
      <img src="/Media/IMG_3276.JPEG" alt="Patient bedroom" class="sect-img" />
    </div>
  </div>
</section>

@* Row 3 — Kitchen / Dining *@
<section class="sect sect-amen-row">
  <div class="hb-container grid-2 align-center">
    <div class="col-media">
      <img src="/Media/IMG_3310.JPEG" alt="Modern kitchen" class="sect-img" />
    </div>
    <div class="col-text">
      <p class="sect-label" data-i18n="amen.r3_label">Kitchen &amp; Dining</p>
      <h2 class="sect-heading" data-i18n="amen.r3_heading">Nutritious, Home-Cooked Meals</h2>
      <p class="sect-body" data-i18n="amen.r3_body">
        Our fully-equipped modern kitchen supports nutritious, home-style meals tailored to every patient's
        dietary needs—because good food is part of good healing.
      </p>
    </div>
  </div>
</section>

@* Row 4 — Therapy / Common Area *@
<section class="sect sect-amen-row alt">
  <div class="hb-container grid-2 align-center grid-reverse">
    <div class="col-text">
      <p class="sect-label" data-i18n="amen.r4_label">Therapy &amp; Common Areas</p>
      <h2 class="sect-heading" data-i18n="amen.r4_heading">Spaces Designed for Recovery</h2>
      <p class="sect-body" data-i18n="amen.r4_body">
        Bright, open spaces support physical, occupational, and speech therapy, as well as social interaction
        and community events. Every detail is designed to feel calm, safe, and motivating.
      </p>
    </div>
    <div class="col-media">
      @* PHOTO PLACEMENT: therapy room or common area photo — pick the one that best shows therapy space *@
      <img src="/Media/IMG_3281.JPEG" alt="Common area" class="sect-img" />
    </div>
  </div>
</section>

@* Row 5 — Staff Workspace *@
<section class="sect sect-amen-row">
  <div class="hb-container grid-2 align-center">
    <div class="col-media">
      <img src="/Media/IMG_0463.JPEG" alt="Nurse station" class="sect-img" />
    </div>
    <div class="col-text">
      <p class="sect-label" data-i18n="amen.r5_label">Nurse Station</p>
      <h2 class="sect-heading" data-i18n="amen.r5_heading">Always Close By</h2>
      <p class="sect-body" data-i18n="amen.r5_body">
        Our centrally located nurse station means skilled staff is always within reach—monitoring, supporting,
        and responding 24/7 to keep patients safe and comfortable.
      </p>
    </div>
  </div>
</section>

@* ── LIFESTYLE & COMFORT SERVICES ── *@
<section class="sect sect-lifestyle alt">
  <div class="hb-container">
    <div class="services-header">
      <p class="sect-label" data-i18n="amen.life_label">Lifestyle &amp; Comfort</p>
      <h2 class="sect-heading" data-i18n="amen.life_heading">More Than Medical Care</h2>
      <p class="services-subheading" data-i18n="amen.life_sub">
        Recovery isn't only clinical. We support every patient's dignity, joy, and connection with on-site
        personal care, transportation, and a full activities program.
      </p>
    </div>

    <div class="lifestyle-grid">
      <div class="lifestyle-card">
        <div class="lifestyle-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="32" cy="22" r="10"/><path d="M14 56c0-10 8-18 18-18s18 8 18 18"/>
          </svg>
        </div>
        <h3 data-i18n="amen.life1_t">Beauty &amp; Personal Care</h3>
        <p data-i18n="amen.life1_b">On-site grooming and personal care services through our partner Beautiian — preserving each patient's sense of self and well-being.</p>
      </div>
      <div class="lifestyle-card">
        <div class="lifestyle-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="8" y="22" width="48" height="22" rx="3"/><circle cx="20" cy="50" r="5"/><circle cx="44" cy="50" r="5"/>
            <path d="M14 22v-4h36v4"/>
          </svg>
        </div>
        <h3 data-i18n="amen.life2_t">Medical Transportation</h3>
        <p data-i18n="amen.life2_b">Non-emergency transportation through Amwest Transportation for medical appointments, hospital visits, and community outings.</p>
      </div>
      <div class="lifestyle-card">
        <div class="lifestyle-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 14v36c0 4-4 6-6 6s-6-2-6-6 4-8 12-8"/>
            <path d="M44 14v32c0 4-4 6-6 6s-6-2-6-6 4-8 12-8"/>
            <path d="M20 14h24M20 22h24"/>
          </svg>
        </div>
        <h3 data-i18n="amen.life3_t">Music &amp; Entertainment</h3>
        <p data-i18n="amen.life3_b">A regular schedule of music, group activities, and entertainment that lifts spirits and supports emotional recovery.</p>
      </div>
      <div class="lifestyle-card">
        <div class="lifestyle-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="32" cy="32" r="20"/><path d="M22 32l6 6 14-14"/>
          </svg>
        </div>
        <h3 data-i18n="amen.life4_t">Games &amp; Recreation</h3>
        <p data-i18n="amen.life4_b">Card games, board games, and recreational programming designed to engage minds, encourage interaction, and create joyful moments.</p>
      </div>
      <div class="lifestyle-card">
        <div class="lifestyle-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 28c0-8 8-14 16-14s16 6 16 14"/>
            <path d="M14 28h36v8c0 6-4 10-10 10H24c-6 0-10-4-10-10v-8z"/>
            <path d="M28 14V8M36 14V8"/>
          </svg>
        </div>
        <h3 data-i18n="amen.life5_t">Dancing &amp; Movement</h3>
        <p data-i18n="amen.life5_b">Gentle dance and movement sessions led by our Activity Director — promoting mobility, balance, and the simple pleasure of music in motion.</p>
      </div>
      <div class="lifestyle-card">
        <div class="lifestyle-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M32 8L40 24l18 2-13 13 3 18-16-9-16 9 3-18-13-13 18-2z"/>
          </svg>
        </div>
        <h3 data-i18n="amen.life6_t">Community &amp; Connection</h3>
        <p data-i18n="amen.life6_b">Group meals, family events, and shared spaces designed to keep patients connected — to each other, to staff, and to the people they love.</p>
      </div>
    </div>
  </div>
</section>

@* ── VISITING HOURS ── *@
<section class="sect sect-visit">
  <div class="hb-container visit-inner">
    <div class="visit-card">
      <div class="visit-icon">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="32" cy="32" r="22"/><path d="M32 18v14l10 6"/>
        </svg>
      </div>
      <h2 class="sect-heading" data-i18n="amen.visit_heading">Visiting Hours</h2>
      <p class="visit-time" data-i18n="amen.visit_time">11:30 AM – 7:00 PM, daily</p>
      <p class="sect-body" data-i18n="amen.visit_body">
        We welcome family and friends throughout the day. Visits are an important part of healing.
      </p>
      <a href="/contact" class="btn-hero btn-hero--filled" data-i18n="amen.visit_btn">Plan a Visit</a>
    </div>
  </div>
</section>

@* ── CTA ── *@
<section class="sect sect-cta">
  <div class="hb-container cta-inner">
    <h2 class="cta-heading" data-i18n="amen.cta_heading">Want to Tour the Facility?</h2>
    <a href="/contact" class="btn-hero btn-hero--white" data-i18n="cta.btn">Contact Us</a>
  </div>
</section>
