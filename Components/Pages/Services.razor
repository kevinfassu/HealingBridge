@* DETAIL: Spinal Cord *@
<section id="prog-spinal" class="sect sect-prog-detail">
  <div class="hb-container">
    <div class="prog-detail-header">
      <span class="prog-detail-tag" data-i18n="services.tag_program">Program</span>
