@page "/"
<PageTitle>Healing Bridge Health</PageTitle>

@* ── HERO — two-column: text left, video right ── *@
<section class="hb-hero">
  <div class="hb-container hero-grid">

    @* Left column: copy *@
    <div class="hero-copy">
      <p class="hero-label" data-i18n="hero.label">WELCOME TO HEALING BRIDGE HEALTH</p>
      <h1 class="hero-title" data-i18n="hero.title">Expert Coordination &amp; Patient-Centered Care</h1>
      <p class="hero-body" data-i18n="hero.body">
        When the hospital stay ends but recovery isn't over, finding the right place to heal shouldn't be hard. 
        We're the bridge home — skilled medical care in a place that actually feels like one, 
        so patients recover with dignity and families have peace of mind.
      </p>
      <div class="hero-btns">
        <a href="#sect-services" class="btn-hero btn-hero--filled" data-i18n="hero.btn_services">Our Services</a>
        <a href="#footer-contact" class="btn-hero btn-hero--outline" data-i18n="hero.btn_contact">Contact Us</a>
      </div>
    </div>

    @* Right column: looping video *@
    <div class="hero-slideshow" @key='"hero-video"'>
      <video autoplay muted loop playsinline 
            style="width:100%;height:100%;object-fit:cover;display:block;"
            preload="auto"
            oncanplay="this.play()">
        <source src="/Media/MainVideo2_web.mp4" type="video/mp4" />
      </video>
    </div>

  </div>
</section>

@* ── MISSION SECTION — photo left, text right ── *@
<section class="sect sect-mission">
  <div class="hb-container grid-2 align-center">
    <div class="col-media">
      <img src="/Media/HealingBridgemain.PNG" alt="Healing Bridge facility" class="sect-img" />
    </div>
    <div class="col-text">
      <p class="sect-label" data-i18n="mission.label">Who We Are</p>
      <h2 class="sect-heading" data-i18n="mission.heading">Healing Bridge Health's Mission</h2>
      <h3 class="sect-subheading" data-i18n="mission.subheading">To provide a better quality of life for every soul that enters our doors.</h3>
      <p class="sect-body" data-i18n="mission.body">
        At Healing Bridge Health Inc., we bridge the healing gap through expert coordination and delivery of
        evidence-informed and patient-centered care that empowers every patient on their journey to recovery.
      </p>
    </div>
  </div>
</section>

@* ── VALUES BLOCK — text left, photo right ── *@
<section class="sect sect-values-block">
  <div class="hb-container grid-2 align-center grid-reverse">
    <div class="col-text">
      <p class="sect-label" data-i18n="values.label">What Guides Us</p>
      <h2 class="sect-heading" data-i18n="values.heading">Competent Care in a Loving Environment</h2>
      <h3 class="sect-subheading" data-i18n="values.subheading">Compassion, clinical excellence, and a pathway to recovery.</h3>
      <p class="sect-body" data-i18n="values.body">
        Every person is unique. Our interdisciplinary team collaborates with you and your family to deliver
        care that is personal, proactive, and supportive—so you can focus on healing.
      </p>
      <ul class="values-list">
        <li><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span data-i18n="values.v0">Compassion</span></li>
        <li><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span data-i18n="values.v1">Collaboration</span></li>
        <li><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span data-i18n="values.v2">Integrity</span></li>
        <li><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span data-i18n="values.v3">Innovation</span></li>
        <li><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span data-i18n="values.v4">Empowerment</span></li>
        <li><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span data-i18n="values.v5">Excellence</span></li>
        <li><svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span data-i18n="values.v6">Cultural Diversity &amp; Inclusivity</span></li>
      </ul>
    </div>
    <div class="col-media">
      <img src="/Media/Inclusive_team.png" alt="Healing Bridge care team" class="sect-img" />
    </div>
  </div>
</section>

@* ── SERVICE CARDS ── *@
<section id="sect-services" class="sect sect-services">
  <div class="hb-container">
    <div class="services-header">
      <p class="sect-label" data-i18n="svc.label">What We Offer</p>
      <h2 class="sect-heading" data-i18n="svc.heading">Our Core Services</h2>
    </div>
    <div class="services-grid">
      <article class="svc-card">
        <div class="svc-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="32" cy="20" r="10"/><path d="M12 52c0-11 8.95-20 20-20s20 9 20 20"/>
            <path d="M44 30l6-4m-6 4l-4-6" opacity=".5"/>
          </svg>
        </div>
        <h3 class="svc-title" data-i18n="svc.card1_title">Care Coordination</h3>
        <p class="svc-body" data-i18n="svc.card1_body">
          Seamless collaboration between physicians, nurses, therapists, and families—ensuring every step of your care plan is aligned and effective.
        </p>
      </article>

      <article class="svc-card">
        <div class="svc-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M32 8v48M8 32h48"/><circle cx="32" cy="32" r="22"/>
          </svg>
        </div>
        <h3 class="svc-title" data-i18n="svc.card2_title">Patient-Centered Care</h3>
        <p class="svc-body" data-i18n="svc.card2_body">
          Evidence-informed, compassionate care tailored to each individual—respecting dignity, preferences, and unique recovery goals.
        </p>
      </article>

      <article class="svc-card">
        <div class="svc-icon">
          <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 52V36a12 12 0 0 1 24 0v16"/><path d="M8 52h48"/><circle cx="32" cy="18" r="6"/>
            <path d="M14 42h36" opacity=".5"/>
          </svg>
        </div>
        <h3 class="svc-title" data-i18n="svc.card3_title">Community Support</h3>
        <p class="svc-body" data-i18n="svc.card3_body">
          Building connections beyond clinical walls—family education, social services, and resources that strengthen the healing journey.
        </p>
      </article>
    </div>
  </div>
</section>

@* ── CTA BANNER ── *@
<section class="sect sect-cta">
  <div class="hb-container cta-inner">
    <h2 class="cta-heading" data-i18n="cta.heading">Your Journey to Healing <strong>Begins Here&hellip;</strong></h2>
    <a href="#footer-contact" class="btn-hero btn-hero--white" data-i18n="cta.btn">Contact Us</a>
  </div>
</section>
